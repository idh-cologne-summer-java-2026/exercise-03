{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "mvn",
            "args": ["clean", "compile", "test-compile"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": ["$javac"]
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "mvn",
            "args": ["test"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": ["Build Project"],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": ["$javac"]
        }
    ]
}
